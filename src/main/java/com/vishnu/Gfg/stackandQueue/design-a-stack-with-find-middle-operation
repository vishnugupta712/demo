//TC O(1)
//SC O(n)
class SpecialStack {

    class Node {
        int data;
        Node prev, next;
        Node(int data) {
            this.data = data;
        }
    }

    private Node head;
    private Node mid;
    private int size;

    public SpecialStack() {
        head = null;
        mid = null;
        size = 0;
    }

    // push(x)
    public void push(int x) {
        Node node = new Node(x);
        node.next = head;

        if (head != null)
            head.prev = node;

        head = node;
        size++;

        if (size == 1)
            mid = node;
        else if (size % 2 != 0)
            mid = mid.prev;
    }

    // pop()
    public int pop() {
        if (size == 0)
            throw new RuntimeException("Stack empty");

        int val = head.data;
        head = head.next;

        if (head != null)
            head.prev = null;

        size--;

        if (size > 0 && size % 2 == 0)
            mid = mid.next;

        return val;
    }

    // findMiddle()
    public int findMiddle() {
        if (size == 0)
            throw new RuntimeException("Stack empty");
        return mid.data;
    }

    // deleteMiddle()
    public void deleteMiddle() {
        if (size == 0)
            throw new RuntimeException("Stack empty");

        Node m = mid;

        if (m.prev != null)
            m.prev.next = m.next;

        if (m.next != null)
            m.next.prev = m.prev;

        if (size % 2 == 0)
            mid = m.next;
        else
            mid = m.prev;

        size--;
    }
}
6️⃣ Time & Space Complexity
Operation	Time
push	O(1)
pop	O(1)
findMiddle	O(1)
deleteMiddle	O(1)
Space: O(n) (DLL nodes)

